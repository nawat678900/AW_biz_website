RewriteRule ^th/contact\.html$ /th/contact/ [R=301,L]
RewriteRule ^th/faq\.html$ /th/faq/ [R=301,L]
RewriteRule ^th/privacy\.html$ /th/privacy-policy/ [R=301,L]
RewriteRule ^th/services/visa\.html$ /th/visa-services/ [R=301,L]
RewriteRule ^th/services/work-permit\.html$ /th/work-permit/ [R=301,L]
RewriteRule ^th/services/business-accounting\.html$ /th/business-services/ [R=301,L]
